{
  "name": "docguard-vscode",
  "displayName": "DocGuard — CDD Compliance",
  "description": "Canonical-Driven Development (CDD) enforcement for VS Code. Inline warnings, CDD score in status bar, and guard commands.",
  "version": "0.4.0",
  "publisher": "raccioly",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/raccioly/docguard"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Linters", "Other"],
  "keywords": [
    "canonical-driven-development",
    "cdd",
    "documentation",
    "docguard",
    "governance"
  ],
  "activationEvents": [
    "workspaceContains:.docguard.json",
    "workspaceContains:docs-canonical",
    "workspaceContains:AGENTS.md"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "docguard.audit",
        "title": "DocGuard: Audit Documentation"
      },
      {
        "command": "docguard.guard",
        "title": "DocGuard: Guard (Validate)"
      },
      {
        "command": "docguard.score",
        "title": "DocGuard: Show CDD Score"
      },
      {
        "command": "docguard.badge",
        "title": "DocGuard: Generate Badges"
      },
      {
        "command": "docguard.init",
        "title": "DocGuard: Initialize CDD Docs"
      },
      {
        "command": "docguard.refresh",
        "title": "DocGuard: Refresh Score"
      },
      {
        "command": "docguard.fix",
        "title": "DocGuard: Find & Fix Issues"
      },
      {
        "command": "docguard.fixAuto",
        "title": "DocGuard: Auto-Fix Missing Docs"
      }
    ],
    "configuration": {
      "title": "DocGuard",
      "properties": {
        "docguard.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh CDD score when canonical docs change"
        },
        "docguard.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show CDD score in the status bar"
        },
        "docguard.nodePath": {
          "type": "string",
          "default": "node",
          "description": "Path to Node.js executable"
        },
        "docguard.scoreThreshold": {
          "type": "number",
          "default": 60,
          "description": "Minimum acceptable CDD score (below this shows warning)"
        }
      }
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0"
  }
}
